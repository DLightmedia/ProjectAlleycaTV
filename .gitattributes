# Force LF line endings for all shell scripts on every platform
*.sh        text eol=lf
*.proto     text eol=lf
*.py        text eol=lf
*.conf      text eol=lf
*.service   text eol=lf
*.yaml      text eol=lf
*.json      text eol=lf
*.md        text eol=lf

# Treat these as binary so Git never touches their line endings
*.mp4       binary
*.jpg       binary
*.jpeg      binary
*.png       binary
*.gif       binary
